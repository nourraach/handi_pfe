{
  "name": "auth-service",
  "version": "1.0.0",
  "private": true,
  "description": "Microservice d'authentification HandiTalents",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "verification-types": "tsc --noEmit -p tsconfig.json",
    "drizzle:generer": "drizzle-kit generate",
    "drizzle:migrer": "drizzle-kit migrate",
    "creer-admin": "ts-node scripts/creer-admin.ts",
    "injecter-comptes": "ts-node scripts/injecter-comptes.ts",
    "activer-candidat": "ts-node scripts/activer-candidat.ts",
    "initialiser-profils": "ts-node scripts/initialiser-profils.ts",
    "tester-api-profils": "ts-node scripts/tester-api-profils.ts",
    "tester-gestion-utilisateurs": "ts-node scripts/tester-gestion-utilisateurs.ts",
    "tester-tests-psychologiques": "ts-node scripts/tester-tests-psychologiques.ts",
    "tester-processus-candidature": "ts-node scripts/tester-processus-candidature.ts",
    "tester-processus-simple": "ts-node scripts/tester-processus-simple.ts",
    "test-activation-entreprise": "ts-node scripts/test-activation-entreprise.ts",
    "creer-test-exemple": "ts-node scripts/creer-test-exemple.ts",
    "seed:donnees-reelles": "node scripts/seed-donnees-reelles.js",
    "matching:recompute": "ts-node scripts/generer-recommandations.ts",
    "matching:test-flow": "ts-node scripts/tester-flow-recommandation.ts",
    "matching:init-vector": "ts-node scripts/init-pgvector-matching.ts",
    "matching:sync-embeddings": "ts-node scripts/sync-embeddings.ts"
  },
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.6",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.16.3",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^7.0.0",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
